# 이 파일을 terraform.tfvars 로 복사한 후 실제 값으로 교체하세요.
# terraform.tfvars 는 .gitignore 로 커밋되지 않습니다.

aws_region   = "ap-northeast-2"
project_name = "ditto"
environment  = "prod"

# AWS 콘솔 > EC2 > 키 페어에서 미리 생성 후 이름 입력
key_pair_name = "ditto-keypair"

# SSH / Grafana / Prometheus 접근 허용 IP (팀원 공인 IP 목록)
# curl ifconfig.me 로 본인 IP 확인
admin_cidr_blocks = [
  "111.222.333.444/32",  # 팀원 A
  "111.222.333.555/32",  # 팀원 B
]

# S3 버킷명: 전 세계에서 유일해야 함 (소문자, 숫자, 하이픈만 허용)
s3_media_bucket_name = "ditto-media-prod-change-me"

# ditto-db 인스턴스 자격증명. GitHub Secret ENV_PROD의 DB_USERNAME/DB_PASSWORD/
# MONGO_USERNAME/MONGO_PASSWORD 와 반드시 동일한 값으로 맞출 것.
db_username    = "ditto"
db_password    = "change-me-match-env-prod"
mongo_username = "ditto"
mongo_password = "change-me-match-env-prod"

# ditto-db 프라이빗 서브넷(10.0.10.0/24) 내 고정 IP. ENV_PROD의 DB_HOST/REDIS_HOST/
# MONGO_HOST/KAFKA_HOST 와 반드시 동일한 값으로 맞출 것.
db_private_ip = "10.0.10.0"