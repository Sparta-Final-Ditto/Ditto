server:
  port: 8084

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/ditto_chat
    username: postgres
    password: postgres
  jpa:
    hibernate:
      ddl-auto: create-drop
  data:
    mongodb:
      uri: mongodb://localhost:27017/ditto_chat
    redis:
      host: localhost
      port: 6379
  kafka:
    bootstrap-servers: localhost:9092