server:
  port: 8083

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/ditto_match
    username: postgres
    password: postgres
  jpa:
    hibernate:
      ddl-auto: create-drop
  data:
    redis:
      host: localhost
      port: 6379
  kafka:
    bootstrap-servers: localhost:9092

ai-service:
  url: http://localhost:8090
