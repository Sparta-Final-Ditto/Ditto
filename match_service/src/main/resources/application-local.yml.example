server:
  port: 8083

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/ditto_match
    username: postgres
    password: postgres
  jpa:
    hibernate:
      ddl-auto: validate
  data:
    redis:
      host: localhost
      port: 6379
  kafka:
    bootstrap-servers: localhost:9092
  ai:
    ollama:
      base-url: http://localhost:11434
      chat:
        model: llama3.2
        options:
          timeout: 10s
  flyway:
    enabled: true
    locations: classpath:db/migration

management:
  endpoints:
    web:
      exposure:
        include: health, info, prometheus, metrics
  metrics:
    tags:
      application: match-service
  prometheus:
    metrics:
      export:
        enabled: true
  tracing:
    sampling:
      probability: 1.0
  zipkin:
    tracing:
      endpoint: http://localhost:9411/api/v2/spans

embedding-service:
  url: http://localhost:8090

feign:
  client:
    config:
      user-service:
        url: http://localhost:8080

springdoc:
  swagger-ui:
    path: /swagger-ui.html