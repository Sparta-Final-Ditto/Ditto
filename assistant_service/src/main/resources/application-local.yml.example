server:
  port: 8086

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/ditto_assistant
    username: postgres
    password: postgres
  jpa:
    hibernate:
      ddl-auto: create-drop
  ai:
    ollama:
      base-url: http://localhost:11434
      chat:
        model: llama3.2
      embedding:
        model: nomic-embed-text
    vectorstore:
      pgvector:
        initialize-schema: true
        dimensions: 768   # nomic-embed-text 임베딩 차원
  flyway:
    enabled: true
    locations: classpath:db/migration

assistant:
  llm:
    provider: ollama

springdoc:
  swagger-ui:
    path: /swagger-ui.html
