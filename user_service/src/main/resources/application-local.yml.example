server:
  port: 8081

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/ditto_user
    username: postgres
    password: postgres
  jpa:
    hibernate:
      ddl-auto: create-drop
  data:
    redis:
      host: localhost
      port: 6379

jwt:
  secret: ditto-dev-secret-key-must-be-32-chars-long!!
  expiration: 86400000
  refresh-expiration: 604800000
