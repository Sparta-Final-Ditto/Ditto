server:
  port: 8080

spring:
  main:
    web-application-type: reactive
  cloud:
    gateway:
      server:
        webflux:
          routes:
            - id: user-service
              uri: http://localhost:8081
              predicates:
                - Path=/api/v1/auth/**,/api/v1/users/**
            - id: feed-service
              uri: http://localhost:8082
              predicates:
                - Path=/api/v1/feeds/**,/api/v1/posts/**
            - id: match-service
              uri: http://localhost:8083
              predicates:
                - Path=/api/v1/matching/**
            - id: chat-service
              uri: http://localhost:8084
              predicates:
                - Path=/api/v1/chat/**
            - id: chat-websocket
              uri: ws://localhost:8084
              predicates:
                - Path=/ws-chat,/ws-chat/**
            - id: notification-service
              uri: http://localhost:8085
              predicates:
                - Path=/api/v1/notifications/**

jwt:
  secret: ditto-dev-secret-key-must-be-32-chars-long!!
