server:
  port: 8082

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/ditto_feed
    username: postgres
    password: postgres
  jpa:
    show-sql: true
    hibernate:
      ddl-auto: create-drop
    defer-datasource-initialization: true
  sql:
    init:
      mode: always
  data:
    redis:
      host: localhost
      port: 6379
      timeout: 500ms # Redis 지연 장애 시 빠른 Feign fall-through (Lettuce 기본 60초)
  kafka:
    bootstrap-servers: localhost:9092
    producer:
      acks: all
      retries: 3
      properties:
        enable.idempotence: true
        delivery.timeout.ms: 10000
        request.timeout.ms: 5000
  cloud:
    openfeign:
      client:
        config:
          match-service:
            connect-timeout: 500
            read-timeout: 1000
          user-service:
            connect-timeout: 500
            read-timeout: 1000

cloud:
  aws:
    s3:
      bucket: ditto-media-local
    region:
      static: ap-northeast-2
    credentials:
      access-key: your-access-key
      secret-key: your-secret-key

app:
  cloudfront:
    domain: https://your-cloudfront-domain.cloudfront.net
  kakao:
    api-key: your-kakao-api-key
  matching-service:
    base-url: http://localhost:8083
    timeout-ms: 1000
  user-service:
    base-url: http://localhost:8081
    timeout-ms: 1000
  cache: # Feign 결과 Cache-Aside TTL (미설정 시 코드 기본값 3m/10m)
    followings-ttl: 3m
    recommendations-ttl: 10m
  outbox:
    publish:
      interval-ms: 5000
      batch-size: 100
    monitor:
      interval-ms: 60000
    replay:
      interval-ms: 3600000
      batch-size: 100
  post-hard-delete:
    retention-days: 30
    chunk-size: 100
    cron: "0 0 4 * * *"

resilience4j:
  circuitbreaker:
    circuit-breaker-aspect-order: 1
    instances:
      matchServiceClient:
        sliding-window-type: COUNT_BASED
        sliding-window-size: 30
        minimum-number-of-calls: 20
        failure-rate-threshold: 50
        slow-call-rate-threshold: 50
        slow-call-duration-threshold: 700ms
        wait-duration-in-open-state: 15s
        permitted-number-of-calls-in-half-open-state: 5
        automatic-transition-from-open-to-half-open-enabled: true
      userServiceClient:
        sliding-window-type: COUNT_BASED
        sliding-window-size: 30
        minimum-number-of-calls: 20
        failure-rate-threshold: 50
        slow-call-rate-threshold: 50
        slow-call-duration-threshold: 700ms
        wait-duration-in-open-state: 15s
        permitted-number-of-calls-in-half-open-state: 5
        automatic-transition-from-open-to-half-open-enabled: true
  retry:
    retry-aspect-order: 2
    instances:
      matchServiceClient:
        max-attempts: 2
        wait-duration: 100ms
        enable-exponential-backoff: true
        exponential-backoff-multiplier: 2
      userServiceClient:
        max-attempts: 2
        wait-duration: 100ms
        enable-exponential-backoff: true
        exponential-backoff-multiplier: 2
